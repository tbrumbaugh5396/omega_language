(register-macro! defmacro
    (name params body)
    (list (quote register-macro!)
        (list (quote quote) name)
        params
        body))


(defmacro let (bindings body)
    ((lambda (vars vals)
        (append (list (list (quote lambda) vars body))
            vals))
    (map first bindings)
    (map second bindings)))


; reader macro
(defmacro set-reader-macro (char handler)
    (list (quote register-reader-macro!) char handler))
  

(define qq-expand (lambda (x)
    (match
        ( (atom x) 
            (list (quote quote) x))
 
        ( (equals x (quote ()))
            (quote ()))
 
        ((equals (start x) (quote unquote))
            (start (rest x)))
    
        (1
            (list (quote prepend)
            (qq-expand (start x))
            (qq-expand (rest x)))))))


(define qq-expand (lambda (x level)
    (match
        ((atom x) (list 'quote x))
        ((equals (start x) 'quasiquote)
        (list 'list ''quasiquote (qq-expand (second x) (+ level 1))))
        ((equals (start x) 'unquote)
        (if (equals level 0)
            (second x)
            (list 'list ''unquote (qq-expand (second x) (- level 1)))))
        (1 (list 'prepend (qq-expand (start x) level) (qq-expand (rest x) level))))))


(defmacro quasiquote (x) 
    (qq-expand x))


(defmacro unquote-slicing (x)
    (list (quote evaluate) x))


