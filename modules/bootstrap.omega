(define *macros* (quote (lower define-type)))

;; 2. Define the predicate
(define is-macro? (lambda (sym) (contains? *macros* sym)))

;; 3. Define the manual expander
;; This simply calls the macro logic without evaluating the result
(define macroexpand (lambda (expr)
      (if (atom expr)
          expr
          (if (is-macro? (start expr))
              (lower-node (second expr)) ;; Specialized for 'lower'
              expr))))


(define-type Stream ((SCons head tail)))

(define *adt-tags* (prepend (quote SCons) *adt-tags*))


(defmacro delay (expr)
  (list (quote lambda) (quote ()) expr))


(define force (lambda (thunk) (thunk)))

(define ones (lambda () 
      (SCons 1 (delay (ones)))))

(start (rest (ones)))


(start (rest (force (second (rest (ones))))))

(lower (SCons 1 (delay (ones))))


(define ones 0)


(define ones (lambda () 
      (SCons 1 (delay (ones)))))


(define take (lambda (n stream-func)
      (if (equals n 0)
          (quote ())
          (begin
            (define s (stream-func))
            (prepend (second s) ;; The head
                     (take (- n 1) (force (third s))))))))


(define ones-gen (lambda (self) 
      (SCons 1 (delay (self self)))))


(define ones (lambda () (ones-gen ones-gen)))


(lower (ones-gen ones-gen))

(lower (SCons 1 (delay (ones-gen ones-gen))))

