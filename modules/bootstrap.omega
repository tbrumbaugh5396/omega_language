(defmacro evaluate (expr) (list (quote evaluate) expr))




; Type
(define *adt-tags* (quote (Some None)))

(defmacro define-type (name constructors)
    (prepend (quote list)
        (map (lambda (ctor)
            (if (atom ctor)
                (list (quote define) 
                      ctor
                      (list (quote lambda) (quote ())
                          (list (quote list) (list (quote quote) ctor))))
                (list (quote define) 
                      (start ctor)
                      (list (quote lambda) (rest ctor)
                            (prepend (quote list)
                                      (prepend (list (quote quote) (start ctor))
                                      (rest ctor)))))))
            constructors)))

(define-type Option ((Some x) (None)))


(define *adt-tags* (quote ()))

(defmacro define-type (name constructors)
    (list (quote begin)
        (list (quote define) (quote *adt-tags*) 
            (prepend (quote list) (prepend (quote *adt-tags*) 
                (map (lambda (c) (if (atom c) c (start c))) constructors))))
        (prepend (quote list)
            (map (lambda (ctor)
                (list (quote define) 
                    (if (atom ctor) ctor (start ctor))
                    (list (quote lambda) (quote args)
                        (list (quote prepend) 
                            (list (quote quote) (if (atom ctor) ctor (start ctor))) 
                            (quote args)))))
        constructors))))


(define empty? (lambda (x) (equals x (quote ()))))

(define contains? (lambda (lst sym)
    (if (empty? lst)
        0
        (if (equals (start lst) sym)
            1
            (contains? (rest lst) sym)))))

(define is-constructor? (lambda (sym) (contains? *adt-tags* sym)))

(define lower-node (lambda (expr)
      (if (atom expr)
          (list (quote uam-node) (quote :const) expr)
          (if (is-constructor? (start expr))
              (list (quote uam-node)
                    (quote :adt)
                    (list (quote quote) (start expr))
                    (map lower-node (rest expr)))
              (list (quote uam-node)
                    (quote :apply)
                    (lower-node (start expr))
                    (map lower-node (rest expr)))))))

(defmacro lower (expr)
      (list (quote quote) (lower-node expr)))

(define lower
(lambda (expr)
  (define inner
    (lambda (e)
      (if (atom e)
          (list (quote uam-node) (quote :const) e)
          (if (is-constructor? (start e))
              (list (quote uam-node) (quote :adt) (list (quote quote) (start e))
                    (map inner (rest e)))
              (list (quote uam-node) (quote :apply)
                    (inner (start e))
                    (map inner (rest e)))))))
  (inner expr)))


(lower (Some 42))


(define-type Result ((Ok value) (Err message)))

(define *adt-tags* (prepend (quote Ok) (prepend (quote Err) *adt-tags*)))

(lower (Err "Type Mismatch"))

