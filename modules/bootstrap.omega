(define s (ones))
(second (rest s))
(define thunk (third (rest s)))
(define next-s (force thunk))
(second (rest next-s))


(lower (ones))

(define pos-node (lambda (n expr)
    (if (equals n 1)
        (list (quote start) expr)
        (pos-node (- n 1) (list (quote rest) expr)))))

(defmacro pos (n expr)
  (pos-node n expr))

(define nth (lambda (n s-func)
      (if (equals n 0)
          (pos 2 (s-func))
          (nth (- n 1) (lambda () (force (pos 3 (s-func))))))))

(nth 5 ones)


(define nth-iter (lambda (n s-func)
    (begin
      ;; 1. Initialize the state
      (define current-s s-func)
      (define i n)
      
      ;; 2. The Iteration Loop
      (while (not (equals i 0))
          (begin
            ;; Move to the next state by forcing the tail
            (set! current-s (lambda () (force (pos 3 (current-s)))))
            (set! i (- i 1))))
      
      ;; 3. Return the final value
      (pos 2 (current-s)))))

(define i 0)
(while (less-than i 5) (begin (print i) (set! i (+ i 1))))


(defmacro safe-swap (a b)
  (define g (gensym))
  (list (quote begin)
        (list (quote define) g a)
        (list (quote set!) a b)
        (list (quote set!) b g)))


(define skip-until-end (lambda (stream)
  (begin
    (define t (next-token stream))
    (if (equals t (quote ;/))
        None
        (if (equals t (quote /;))
            (begin (skip-until-end stream) (skip-until-end stream))
            (if (equals t None)
                None
                (skip-until-end stream)))))))


