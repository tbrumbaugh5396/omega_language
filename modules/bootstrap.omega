;; This is a trick: since your apply evaluates args,
;; simply returning the last one works as a 'begin'
(define begin (lambda args
      (last args)))


(define last (lambda (lst)
  (match lst
    ((x) x)             ;; Base case: Only one element left
    ((x . rest) (last rest))))) ;; Recursive case: Keep going


; let
(defmacro let (bindings body)
  ((lambda (vars vals)
     (append (list (list (quote lambda) vars body))
             vals))
   (map first bindings)
   (map second bindings)))

(register-macro! (quote let)
      (list (quote bindings) (quote body))
      (quote (prepend (list (quote lambda) (map first bindings) body)
                      (map second bindings))))

; macro
(register-macro! (quote defmacro)
      (list (quote name) (quote params) (quote body))
      (quote 
        (list (quote let)
              (list (list (quote _)
                          (list (quote register-macro!)
                                (list (quote quote) name)
                                (list (quote quote) params)
                                (list (quote quote) body))))
              (list (quote quote) (list (quote quote) (quote OMEGA-MACRO-REGISTERED))))))

