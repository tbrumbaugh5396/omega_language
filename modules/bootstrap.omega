;; Foreign Function Interface
(define next-token (lambda (stream) 
      (call-method stream "next")))

(define peek-token (lambda (stream) 
      (call-method stream "peek")))

(define clear-stream (lambda (stream) 
      (call-method stream "clear")))

(define read (lambda (stream) 
      (python-read-node stream)))

(define read (lambda (stream)
  (begin
    (define token (next-token stream))
    (if (equals token None) None
      (if (equals token "(") (read-list stream)
        (if (equals token ")") "Error: unexpected )"
          (parse-atom token))))))


; Preprocessing
(define preprocess (lambda (s)
  (let ((padded (tokenize-str s)))
    ;; Imagine a function 'string-replace' that swaps "=>" for "lambda"
    (string-replace padded "=>" "lambda"))))


(define is-string-token? (lambda (t)
  (let ((chars (string->list t)))
    (if (null? chars)
        false
        (equals (char->int (first chars)) 34)))))


(define process-literals (lambda (tokens)
  (if (null? tokens)
      (quote ())
      (let ((t (first tokens)))
        (if (is-string-token? t)
            (prepend (list (quote string-literal) t) 
                     (process-literals (rest tokens)))
            (prepend t 
                     (process-literals (rest tokens))))))))

;; Use a single list wrap so it stays an argument, not a function call
            


(process-literals (quote ("a +" "b")))


(define preprocess (lambda (line)
  (process-literals (tokenize-str line))))

(define preprocess process-literals)

