(define ModuleMap
  (lambda (Source TransformFunc)
    (let ((NewMod (Environment)))
      (map (lambda (key) 
             (define-const (string-append NewMod "." key) 
                           (TransformFunc (call-method Source "get" key))))
           (module-keys Source)))))



(define FS-CAP (new-capability "filesystem"))
(define write-file (new-effect "filesystem" (lambda (path data) (print "Writing to disk..."))))

;; 2. Attempting to use the effect fails by default
(write-file "log.txt" "data")
  ! Type Error: Effect Violation: Missing 'filesystem' capability

;; 3. Grant the capability locally
(with-capability FS-CAP
        (write-file "log.txt" "secure data"))


(define def-secure
  (macro (name effects-list body)
    (list 'define name 
          (list 'lambda (second body) 
                (list ':effects effects-list) 
                (rest (rest body))))))


(define write-log (lambda (msg) (:effects "filesystem") (print msg)))


(define-macro (secure-lambda params effects body)
  (list 'lambda params 
        (list 'quote ':metadata) 
        (list 'quote effects)
        body))


