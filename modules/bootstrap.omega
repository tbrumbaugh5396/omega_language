;; Standardize names
(alias start car)
(alias rest  cdr)
(alias prepend cons)
(alias equals eq)

(define map 
    (lambda (f l)
        (if (equals l (quote ()))
            (quote ())
            (prepend (f (start l)) 
                (map f (rest l))))))

(defmacro cond (c1 c2) 
    (list (quote match) c1 c2))

(defmacro apply (fn args)
    (prepend fn args))



